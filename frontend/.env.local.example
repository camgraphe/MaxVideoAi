# Google Search Console admin SEO cockpit (server-only).
# Use the exact GSC property, for example https://maxvideoai.com/ or sc-domain:maxvideoai.com.
GSC_SITE_URL=sc-domain:maxvideoai.com
# Preferred when Search Console accepts the service account as a property user:
GSC_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# OAuth user fallback when the service account cannot be added in Search Console.
# Authorize a Google user that already has access to the GSC property with:
# https://www.googleapis.com/auth/webmasters.readonly
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GSC_CACHE_TTL_SECONDS=1800
# Optional: override file cache path or disable file cache in serverless runtimes.
# GSC_CACHE_FILE=.cache/seo/gsc-search-analytics.json
# GSC_DISABLE_FILE_CACHE=0

# Engines source (use repo fixtures instead of internal list)
# USE_FIXTURE_ENGINES=1
NEXT_PUBLIC_WORKSPACE_CENTER_GALLERY=false

