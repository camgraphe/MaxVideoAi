{
  "name": "maxvideoai-mock-api",
  "version": "0.1.0",
  "private": true,
  "description": "Mock API server and fixtures for the MaxVideoAI Generate page",
  "license": "BUSL-1.1",
  "author": "MaxVideoAI",
  "dependencies": {
    "lucide-react": "^0.553.0",
    "pg": "^8.11.3",
    "stripe": "^14.24.0"
  },
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "start": "node mock-server.js",
    "healthcheck": "tsx scripts/healthcheck.ts",
    "sanitize:jobs": "node scripts/sanitize-jobs.js",
    "lint:exposure": "node scripts/check-public-exposure.mjs",
    "vercel-build": "NEXT_SKIP_ESLINT=1 npm --prefix frontend run build && rm -rf frontend/.next/cache frontend/tsconfig.tsbuildinfo",
    "model:generate": "node scripts/generate-model-roster.mjs",
    "model:generate:write": "node scripts/generate-model-roster.mjs --write",
    "model:check": "node scripts/validate-model-roster.mjs",
    "model:registry:generate": "node scripts/generate-model-runtime.mjs --write",
    "model:registry:check": "tsx --tsconfig frontend/tsconfig.json scripts/validate-model-registry.ts && node scripts/generate-model-runtime.mjs && pnpm engine:catalog -- --check && pnpm model:generate",
    "model:scaffold": "npm --prefix frontend run models:scaffold --",
    "model:setup": "node scripts/model-setup.mjs",
    "models:audit": "tsx --tsconfig frontend/tsconfig.json scripts/models-audit.mjs",
    "pricing:baseline": "tsx --tsconfig frontend/tsconfig.json scripts/pricing-baseline.ts",
    "pricing:public-baseline": "tsx --tsconfig frontend/tsconfig.json frontend/scripts/pricing-public-baseline.ts",
    "pricing:public-baseline:generate": "tsx --tsconfig frontend/tsconfig.json frontend/scripts/pricing-public-baseline.ts --write",
    "pricing:audit": "tsx --tsconfig frontend/tsconfig.json scripts/pricing-audit.ts",
    "architecture:audit": "node scripts/audit-large-files.mjs",
    "db:migrate:neon": "bash scripts/apply-neon-migrations.sh",
    "neon:branches:check": "node scripts/neon-branch-guard.mjs",
    "neon:branches:prune": "node scripts/neon-branch-guard.mjs --delete-archived",
    "audit:premerge": "rm -rf frontend/.next && pnpm --prefix frontend run build && pnpm test:validate && pnpm --prefix frontend run i18n:check && pnpm --prefix frontend run seo:check && pnpm model:check && pnpm models:audit",
    "sources:check": "node scripts/sources-check.mjs",
    "engine:catalog": "./frontend/node_modules/.bin/tsx scripts/build-engine-catalog.ts",
    "jobs:export": "tsx scripts/export-latest-jobs.ts",
    "test:admin-smoke": "playwright test -c playwright.admin.config.ts",
    "test-videos:process": "node scripts/process-video-gallery.mjs",
    "test-videos:serve": "node scripts/serve-video-gallery.mjs",
    "test:validate": "tsx --tsconfig frontend/tsconfig.json --test tests/*.test.ts"
  },
  "pnpm": {
    "overrides": {
      "@smithy/config-resolver": "4.4.17",
      "basic-ftp": "5.3.1",
      "caniuse-lite": "1.0.30001790",
      "anymatch>picomatch": "2.3.2",
      "eslint>js-yaml": "4.2.0",
      "eslint>minimatch": "3.1.4",
      "express": "4.22.1",
      "fast-xml-builder": "1.2.0",
      "fast-xml-parser": "5.8.0",
      "flatted": "3.4.2",
      "gray-matter>js-yaml": "3.15.0",
      "glob@7.2.3>minimatch": "3.1.4",
      "@fal-ai/server-proxy>picomatch": "4.0.4",
      "@humanwhocodes/config-array>minimatch": "3.1.4",
      "@lhci/utils>js-yaml": "3.15.0",
      "@lhci/cli>tmp": "0.2.7",
      "external-editor>tmp": "0.2.7",
      "lighthouse>ws": "7.5.11",
      "@next/env>postcss": "8.5.10",
      "@parcel/watcher>picomatch": "4.0.4",
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "mdast-util-to-hast": "13.2.1",
      "micromatch>picomatch": "2.3.2",
      "minimatch@3.1.4>brace-expansion": "1.1.13",
      "minimatch@9.0.9>brace-expansion": "2.1.0",
      "ip-address": "10.2.0",
      "path-to-regexp": "0.1.13",
      "postcss": "8.5.10",
      "qs": "6.15.2",
      "sucrase": "3.35.1",
      "tinyglobby>picomatch": "4.0.4",
      "@typescript-eslint/typescript-estree>minimatch": "9.0.9",
      "uuid": "14.0.0",
      "ws@8.18.3": "8.21.0",
      "yaml": "2.8.3"
    }
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/pg": "^8.10.2",
    "tsx": "^4.20.6"
  }
}
